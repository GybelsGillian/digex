									<div class="c-card-blog__tags">
										<span class="c-badge-card">UX/UI</span>
									</div>
									<h3 class="c-card-blog__title">Audyn</h3>
								</header>
								<p class="c-card-blog__date">October 5, 2026</p>
								<a class="c-btn-text" href="#">View details</a>
							</div>
						</article>
					</li>
				</ul>
			</div>
