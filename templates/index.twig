{% extends '_shared/_layouts/_layout-main.twig' %}

{% set title = 'DIGEX - We create digital experiences' %}

{% block scripts %}
	{{ craft.vite.script('src/js/pages/home.js', false) }}
{% endblock %}

{% block content %}
	<header class="s-hero-home">
		{% set homePage = craft.entries.section('pageHome').one() %}

		<div class="container">
			<div class="s-hero-home__inner">
				<div class="s-hero-home__text-container">
					<div class="s-hero-home__heading-container">
						<h1 class="s-hero-home__heading fs-h1-md">
							<span data-text="bold">We</span>
							<span data-text="serif">create</span>
							<br>
							<span data-text="serif">your</span>
							<span data-text="bold">digital</span>
							<span data-text="cursive">experience</span>
						</h1>
						<a class="c-btn-secondary c-btn-secondary--md" href="#">Request your price</a>
					</div>
					<div class="s-hero-home__stats">
						<article>
							<h2>128+</h2>
							<p>128+ projects completed</p>
						</article>
						<article>
							<h2>50+</h2>
							<p>50+ satisfied clients</p>
						</article>
						<article>
							<h2>10+</h2>
							<p>10+ years of experience</p>
						</article>
					</div>
				</div>

				<div class="s-hero-home__reviews">
					<div class="s-hero-home__showreel">
						<img class="s-hero-home__showreel-video" src="/assets/placeholders/showreel.png" alt="Illustration of a showreel">
						<p class="s-hero-home__showreel-text">
							<span>Showreel</span>
							<span>2026</span>
						</p>
					</div>

					<div>
						<span class="c-badge-profile c-badge-profile--lg">
							<img src="" alt="">
						</span>
						<span class="c-badge-profile c-badge-profile--lg">
							<img src="" alt="">
						</span>
						<span class="c-badge-profile c-badge-profile--lg">
							<img src="" alt="">
						</span>
						<span class="c-badge-profile c-badge-profile--lg">
							<img src="" alt="">
						</span>
						<span class="c-badge-profile c-badge-profile--lg">
							<img src="" alt="">
						</span>
					</div>
					<a href="#" class="c-badge-reviews">
						<strong class="c-badge-reviews__rating">4.8</strong>
						<div class="c-badge-reviews__stars"></div>
						<p class="c-badge-reviews__count">15 reviews</p>
					</a>
				</div>

				<img class="s-hero-home__beetle" src="/assets/illustrations/beetle.webp" alt="Illustration of a beetle">
			</p>
		</div>
	</header>

	<main>
