			<div class="s-flowers__wrap">
				<video class="s-flowers__video js-section-flowers-video" src="/assets/test-scroll-3.webm" preload="auto" muted playsinline disablepictureinpicture></video>

				<div class="o-curtain js-curtain">
					<div class="o-curtain__panel js-curtain-panel" data-panel="5"></div>
					<div class="o-curtain__panel js-curtain-panel" data-panel="4"></div>
					<div class="o-curtain__panel js-curtain-panel" data-panel="3"></div>
					<div class="o-curtain__panel js-curtain-panel" data-panel="2"></div>
					<div class="o-curtain__panel js-curtain-panel" data-panel="1"></div>
				</div>
			</div>
		</section>

		<section class="s-cta-projects js-section-cta-projects" style="--projects: 3">
			<div class="s-cta-projects__wrap">
				<div class="s-cta-projects__slide js-section-cta-projects-slide">
					<header class="s-cta-projects__header js-section-cta-projects-slideitem">
