<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		<title>DIGEX - We create digital experiences</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Aguafina+Script&family=Notable&family=Playfair:ital,opsz,wght@0,5..1200,300..900;1,5..1200,300..900&family=Schibsted+Grotesk:ital,wght@0,400..900;1,400..900&display=swap" rel="stylesheet">
		{{ craft.vite.script('src/js/app.js', false) }}
		{{ craft.vite.script('src/js/pages/home.js', false) }}
		{{ craft.vite.script('src/js/utilities.js', false) }}
	</head>
	<body>
		{% include '_shared/_general/_navbar.twig' %}

		<header class="s-hero-home">
			{% set homePage = craft.entries.section('pageHome').one() %}

			<div class="container">
				<div class="s-hero-home__inner">
					<div class="s-hero-home__heading-container">
						<h1 class="s-hero-home__heading fs-h1-md">
							<span data-text="bold">We</span>
							<span data-text="serif">create</span>
							<br>
							<span data-text="serif">your</span>
							<span data-text="bold">digital</span>
							<span data-text="cursive">experience</span>
						</h1>
						<a class="c-btn-secondary c-btn-secondary--md" href="#">Request your price</a>
					</div>
					<div class="s-hero-home__stats">
						<article>
							<h2>128+</h2>
							<p>128+ projects completed</p>
						</article>
						<article>
							<h2>50+</h2>
							<p>50+ satisfied clients</p>
						</article>
						<article>
							<h2>10+</h2>
							<p>10+ years of experience</p>
						</article>
					</div>

					<img class="s-hero-home__beetle" src="/assets/illustrations/beetle.webp" alt="Illustration of a beetle">
				</div>
			</div>
		</header>

		<section class="s-flowers" id="sequenceSection">
			<div class="s-flowers__wrap">
				<canvas class="s-flowers__canvas" id="sequenceCanvas"></canvas>
			</div>
		</section>

		<section style="height: 100vh; display: flex; align-items: center; justify-content: center;">
			<h2 style="font-size: 3rem;">Scroll down to see the animation</h2>
		</section>

	</body>
</html>
