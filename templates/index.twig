<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		<title>Document</title>
		{{ craft.vite.script('src/js/app.js', false) }}
		{{ craft.vite.script('src/js/pages/home.js', false) }}
		{{ craft.vite.script('src/js/utilities.js', false) }}
	</head>
	<body>
		{% include '_shared/_general/_navbar.twig' %}

		<div class="container">
			{{ 'testHello' | t }}
			{% set homePage = craft.entries.section('pageHome').one() %}
			<h1 class="fs-h1-lg">{{ homePage.title }}
				- H1 lg</h1>
			<h1 class="fs-h1-md">{{ homePage.title }}
				- H1 md</h1>
			<h1 class="fs-h1-sm">{{ homePage.title }}
				- H1 sm</h1>
			<h2 class="fs-h2-lg">{{ homePage.title }}
