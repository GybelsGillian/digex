							<img src="/assets/laptop-mockup.webp" alt="Illustration of a flower">
						</picture>
						<div class="c-card-project-lg__text-container">
							<header class="c-card-project-lg__header">
								<h3 class="c-card-project-lg__title">Audyn</h3>
								<p class="c-card-project-lg__description">Lorem ipsum dolor sit amet consectetur adipisicing elit. Nisi facilis atque maxime!</p>
							</header>
							<a href="#" class="c-card-project-lg__link">Explore project</a>
						</div>
					</article>
					<article class="c-card-project-lg js-section-cta-projects-slideitem">
						<picture class="c-card-project-lg__image">
							<source srcset="/assets/laptop-mockup.webp" type="image/webp">
							<img src="/assets/laptop-mockup.webp" alt="Illustration of a flower">
						</picture>
						<div class="c-card-project-lg__text-container">
							<header class="c-card-project-lg__header">
								<h3 class="c-card-project-lg__title">Audyn</h3>
								<p class="c-card-project-lg__description">Lorem ipsum dolor sit amet consectetur adipisicing elit. Nisi facilis atque maxime!</p>
							</header>
							<a href="#" class="c-card-project-lg__link">Explore project</a>
						</div>
					</article>
					<footer class="s-cta-projects__footer js-section-cta-projects-slideitem">
						<p class="fs-body-xxl">Explore our complete collection of digital creations.</p>
						<a class="c-btn-secondary c-btn-secondary--md c-btn-secondary--dark" href="#">View portfolio</a>
					</footer>
				</div>
			</div>
		</section>

		<section class="s-development js-section-development">
			<div class="s-development__wrap">
				<video class="s-development__video" src="/assets/textures/dark-moody-clouds.mov" autoplay muted loop></video>
				<img class="s-development__image js-section-development-rock" src="/assets/textures/black-rock-stone-podium.png" alt="Illustration of a flower">
			</div>
		</section>

		<section class="s-motiondesign js-section-motiondesign">
			<div class="s-motiondesign__wrap">
